{
  "scopeName": "source.http",
  "patterns": [
    { "include": "#comment" },
    { "include": "#separator" },
    { "include": "#variable-definition" },
    { "include": "#request-line" },
    { "include": "#header" },
    { "include": "#variable-reference" },
    { "include": "#json-body" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.http"
    },
    "separator": {
      "match": "^###.*$",
      "name": "comment.block.separator.http"
    },
    "variable-definition": {
      "match": "^@(\\w+)\\s*=\\s*(.*)$",
      "captures": {
        "1": { "name": "variable.other.definition.http" },
        "2": { "name": "string.unquoted.value.http" }
      }
    },
    "request-line": {
      "match": "^(GET|POST|PUT|DELETE|PATCH|HEAD|OPTIONS|TRACE|CONNECT)\\s+(.+?)(?:\\s+(HTTP/\\S+))?\\s*$",
      "captures": {
        "1": { "name": "keyword.control.method.http" },
        "2": { "name": "markup.underline.link.http" },
        "3": { "name": "constant.language.http-version.http" }
      }
    },
    "header": {
      "match": "^([\\w-]+)\\s*:\\s*(.*)$",
      "captures": {
        "1": { "name": "entity.name.tag.header-name.http" },
        "2": { "name": "string.unquoted.header-value.http" }
      }
    },
    "variable-reference": {
      "match": "\\{\\{(\\w+)\\}\\}",
      "captures": {
        "0": { "name": "variable.other.readwrite.http" },
        "1": { "name": "variable.other.readwrite.http" }
      }
    },
    "json-body": {
      "begin": "^\\s*\\{",
      "end": "^\\s*\\}",
      "name": "meta.embedded.block.json",
      "patterns": [
        { "include": "source.json" },
        { "include": "#variable-reference" }
      ]
    }
  }
}
